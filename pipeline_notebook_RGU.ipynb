        "# =====================================================\n",
        "# LSTM: Normalization for outage\n",
        "# =====================================================\n",
        "\n",
        "out_mu = np.nanmean(outage_train)\n",
        "out_sd = np.nanstd(outage_train)\n",
        "out_sd = max(out_sd, 1.0)\n",
        "\n",
        "def z_norm(arr, mu, sd):\n",
        "    return (arr - mu) / sd\n",
        "\n",
        "def z_denorm(arr, mu, sd):\n",
        "    return arr * sd + mu\n",
        "\n",
        "outage_train_z = z_norm(outage_train, out_mu, out_sd)\n",
        "outage_full_z = z_norm(outage, out_mu, out_sd)\n",
        "\n",
        "print(f\"Outage normalization: mu={out_mu:.2f}, sd={out_sd:.2f}\")"
