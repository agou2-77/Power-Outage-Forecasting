        "outage = ds_train.out.transpose(\"timestamp\", \"location\").values.astype(float)   # (T, L)\n",
        "weather = ds_train.weather.transpose(\"timestamp\", \"location\", \"feature\").values.astype(float)  # (T, L, F)\n",
