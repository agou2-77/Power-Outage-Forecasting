      "source": [
        "# RMSE evaluation function\n",
        "def rmse(y_true, y_pred):\n",
        "    return float(np.sqrt(np.mean((np.asarray(y_true) - np.asarray(y_pred))**2)))\n",
        "\n",
        "def evaluate_per_county(truth, pred_df, locations):\n",
        "    \"\"\"truth: (H, L), pred_df: DataFrame with timestamp, location, pred\"\"\"\n",
        "    rmses = []\n",
        "    for i, loc in enumerate(locations):\n",
        "        loc_str = str(loc)\n",
        "        loc_pred = pred_df[pred_df['location'].astype(str) == loc_str]['pred'].values\n",
        "        if len(loc_pred) == truth.shape[0]:\n",
        "            rmses.append(rmse(truth[:, i], loc_pred))\n",
        "        else:\n",
        "            rmses.append(np.nan)\n",
        "    return rmses\n",
        "\n",
        "print(\"Shared setup complete.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "hEqAeP8XkzuP"
      },
      "source": [
        "---\n",
        "---\n",
        "# MODEL A: XGBoost (Direct Multi-Horizon Forecasting)\n",
        "Uses top-20 raw weather features + outage lags + rolling stats + temporal features.\n",
        "\n",
        "Strategy: one model per horizon (h=1,...,H). Each model predicts outage at time t+h given features at time t."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "LkKGzPVZkzuP",
        "outputId": "d549597b-e52d-4bc4-a819-c7838dab11ea"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Building XGBoost feature matrix (training)...\n",
            "Feature dim: 64, Valid timesteps per county: 2041\n"
          ]
        }
      ],
      "source": [
        "# =====================================================\n",
        "# XGBoost: Build feature matrix\n",
        "# =====================================================\n",
        "\n",
        "N_LAGS = 24  # outage lag features\n",
        "ROLL_WINDOWS = [6, 12, 24]  # rolling mean windows for top weather features\n",
        "\n",
        "def build_xgb_features(outage_arr, weather_arr, timestamps_arr, mean_tracked,\n",
        "                       top_feat_idx, roll_feat_idx, roll_windows, n_lags):\n",
        "    \"\"\"\n",
        "    Build feature matrix for XGBoost.\n",
        "    For each (t, county) pair, features are:\n",
        "      - outage lags: y_{t-1}, ..., y_{t-n_lags}\n",
        "      - top-K weather at time t\n",
        "      - rolling means of top-5 weather features\n",
        "      - temporal: hour_sin, hour_cos, dow_sin, dow_cos\n",
        "      - county size: log(mean_tracked)\n",
        "    Returns: feature_dict keyed by county index, each value is (T_valid, D) array\n",
        "    \"\"\"\n",
        "    T_arr, L_arr = outage_arr.shape\n",
        "    ts_pd = pd.to_datetime(timestamps_arr)\n",
        "\n",
        "    # Precompute temporal features for all timestamps\n",
        "    hour = ts_pd.hour.values\n",
        "    dow = ts_pd.dayofweek.values\n",
        "    hour_sin = np.sin(2 * np.pi * hour / 24)\n",
        "    hour_cos = np.cos(2 * np.pi * hour / 24)\n",
        "    dow_sin = np.sin(2 * np.pi * dow / 7)\n",
        "    dow_cos = np.cos(2 * np.pi * dow / 7)\n",
        "\n",
        "    # Precompute rolling weather for each county\n",
        "    # weather_arr: (T, L, F)\n",
        "    roll_feats_all = {}  # (county_idx) -> (T, n_roll_features)\n",
        "    for li in range(L_arr):\n",
        "        roll_list = []\n",
        "        for fi in roll_feat_idx:\n",
        "            series = pd.Series(weather_arr[:, li, fi])\n",
        "            for w in roll_windows:\n",
        "                roll_list.append(series.rolling(w, min_periods=1).mean().values)\n",
        "        roll_feats_all[li] = np.column_stack(roll_list)  # (T, n_roll*n_windows)\n",
        "\n",
        "    # Valid start index (need n_lags history)\n",
        "    start = n_lags\n",
        "\n",
        "    feature_dict = {}\n",
        "    for li in range(L_arr):\n",
        "        rows = []\n",
        "        for t in range(start, T_arr):\n",
        "            feat = []\n",
        "            # Outage lags\n",
        "            for lag in range(1, n_lags + 1):\n",
        "                feat.append(outage_arr[t - lag, li])\n",
        "            # Top-K weather at time t\n",
        "            for fi in top_feat_idx:\n",
        "                feat.append(weather_arr[t, li, fi])\n",
        "            # Rolling weather\n",
        "            feat.extend(roll_feats_all[li][t])\n",
        "            # Temporal\n",
        "            feat.extend([hour_sin[t], hour_cos[t], dow_sin[t], dow_cos[t]])\n",
        "            # County size\n",
        "            feat.append(np.log1p(mean_tracked[li]))\n",
        "            rows.append(feat)\n",
        "        feature_dict[li] = np.array(rows, dtype=np.float32)  # (T_valid, D)\n",
        "\n",
        "    return feature_dict, start\n",
        "\n",
        "print(\"Building XGBoost feature matrix (training)...\")\n",
        "xgb_feat_train, xgb_start = build_xgb_features(\n",
        "    outage_train, weather_train, ts_train, mean_tracked,\n",
        "    top_feat_idx, roll_feat_idx, ROLL_WINDOWS, N_LAGS\n",
        ")\n",
        "D_xgb = xgb_feat_train[0].shape[1]\n",
        "print(f\"Feature dim: {D_xgb}, Valid timesteps per county: {xgb_feat_train[0].shape[0]}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 10,
