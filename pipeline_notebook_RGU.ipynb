      "source": [
        "# =====================================================\n",
        "# LSTM: Build sliding windows\n",
        "# =====================================================\n",
        "\n",
        "def build_lstm_windows(outage_z, weather_pca, lookback, horizon):\n",
        "    \"\"\"\n",
        "    Build sliding windows for LSTM.\n",
        "    Input: [outage_z, weather_pca] over lookback window\n",
        "    Target: outage_z over horizon window\n",
        "    \"\"\"\n",
        "    T_w, L_w = outage_z.shape\n",
        "    N_pca = weather_pca.shape[2]\n",
        "    input_dim = 1 + N_pca  # outage + pca weather\n",
        "\n",
        "    X_list, Y_list = [], []\n",
        "\n",
        "    for li in range(L_w):\n",
        "        out_loc = outage_z[:, li]  # (T,)\n",
        "        w_loc = weather_pca[:, li, :]  # (T, N_pca)\n",
        "\n",
        "        # Combine outage + weather as input features\n",
        "        X_loc = np.column_stack([out_loc.reshape(-1, 1), w_loc])  # (T, 1+N_pca)\n",
        "\n",
        "        N = T_w - lookback - horizon + 1\n",
        "        if N <= 0:\n",
        "            continue\n",
        "        for i in range(N):\n",
        "            X_list.append(X_loc[i:i + lookback])              # (lookback, input_dim)\n",
        "            Y_list.append(out_loc[i + lookback:i + lookback + horizon])  # (horizon,)\n",
        "\n",
        "    X = np.array(X_list, dtype=np.float32)\n",
        "    Y = np.array(Y_list, dtype=np.float32)\n",
        "    return X, Y, input_dim\n",
        "\n",
        "print(\"Window builder ready.\")"
      ]
    },
    {
      "cell_type": "code",
