      },
      "source": [
        "---\n",
        "## 4. Three-Model Ensemble"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 40,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "OyibPTsy2TdA",
        "outputId": "e48010d3-dc0a-43a5-c835-32863fe2e6f2"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Searching for optimal 3-model ensemble weights...\n",
            "(This tests ~1000 weight combinations)\n",
            "\n",
            "24h Best: SARIMAX=0.20, XGB=0.80, LSTM=0.00 -> RMSE=849.5957\n",
            "48h Best: SARIMAX=0.00, XGB=0.45, LSTM=0.55 -> RMSE=639.5549\n"
          ]
        }
      ],
      "source": [
        "# =====================================================\n",
        "# Ensemble: 3-model weighted average\n",
        "# Grid search over (w_sarimax, w_xgb, w_lstm) on validation\n",
        "# =====================================================\n",
        "\n",
        "def ensemble_3_predictions(df_s, df_x, df_l, w_s, w_x, w_l):\n",
        "    \"\"\"Weighted average of three prediction DataFrames.\"\"\"\n",
        "    # Align all DataFrames by timestamp + location\n",
        "    df = df_s.copy().sort_values(['timestamp', 'location']).reset_index(drop=True)\n",
        "    pred_s = df['pred'].values\n",
        "    pred_x = df_x.sort_values(['timestamp', 'location']).reset_index(drop=True)['pred'].values\n",
        "    pred_l = df_l.sort_values(['timestamp', 'location']).reset_index(drop=True)['pred'].values\n",
        "    df['pred'] = w_s * pred_s + w_x * pred_x + w_l * pred_l\n",
        "    df['pred'] = df['pred'].clip(lower=0)\n",
        "    return df\n",
        "\n",
        "print(\"Searching for optimal 3-model ensemble weights...\")\n",
        "print(\"(This tests ~1000 weight combinations)\\n\")\n",
        "\n",
        "step = 0.05\n",
        "best_w_24 = (1/3, 1/3, 1/3)\n",
        "best_rmse_24 = float('inf')\n",
        "best_w_48 = (1/3, 1/3, 1/3)\n",
        "best_rmse_48 = float('inf')\n",
        "\n",
        "weight_results_24 = []\n",
        "weight_results_48 = []\n",
        "\n",
        "try:\n",
        "    for w_s in np.arange(0.0, 1.0 + step, step):\n",
        "        for w_x in np.arange(0.0, 1.0 - w_s + step, step):\n",
        "            w_l = 1.0 - w_s - w_x\n",
        "            if w_l < -0.01:  # float tolerance\n",
        "                continue\n",
        "            w_l = max(w_l, 0.0)\n",
        "\n",
        "            # 24h\n",
        "            ens_24 = ensemble_3_predictions(\n",
        "                sarimax_val_24h_df, xgb_val_24h_df, lstm_val_24h_df, w_s, w_x, w_l\n",
        "            )\n",
        "            r24 = np.nanmean(evaluate_per_county(val_24h_truth, ens_24, locations))\n",
        "            weight_results_24.append((w_s, w_x, w_l, r24))\n",
        "            if r24 < best_rmse_24:\n",
        "                best_rmse_24 = r24\n",
        "                best_w_24 = (w_s, w_x, w_l)\n",
        "\n",
        "            # 48h\n",
        "            ens_48 = ensemble_3_predictions(\n",
        "                sarimax_val_48h_df, xgb_val_48h_df, lstm_val_48h_df, w_s, w_x, w_l\n",
        "            )\n",
        "            r48 = np.nanmean(evaluate_per_county(val_48h_truth, ens_48, locations))\n",
        "            weight_results_48.append((w_s, w_x, w_l, r48))\n",
        "            if r48 < best_rmse_48:\n",
        "                best_rmse_48 = r48\n",
        "                best_w_48 = (w_s, w_x, w_l)\n",
        "\n",
        "    print(f\"24h Best: SARIMAX={best_w_24[0]:.2f}, XGB={best_w_24[1]:.2f}, LSTM={best_w_24[2]:.2f} -> RMSE={best_rmse_24:.4f}\")\n",
        "    print(f\"48h Best: SARIMAX={best_w_48[0]:.2f}, XGB={best_w_48[1]:.2f}, LSTM={best_w_48[2]:.2f} -> RMSE={best_rmse_48:.4f}\")\n",
        "\n",
        "except NameError as e:\n",
        "    print(f\"Missing model predictions: {e}\")\n",
        "    print(\"Run pipeline_notebook.ipynb first and keep DataFrames in memory,\")\n",
        "    print(\"or save validation predictions to CSV and load them above.\")"
      ]
    },
