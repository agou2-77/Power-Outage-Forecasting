        "## 2. Feature Engineering (shared)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 6,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "foqLW6amkzuP",
        "outputId": "4160f32c-bc3a-4979-a386-28d0b8ad6536"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Top 20 features: ['sdwe_1', 'siconc', 'ssrun', 'cicep', 'tcoli', 'tcolw', 'tp', 'crain', 'prate', 'csnow', 'unknown_7', 'unknown_9', 'ltng', 'aod', 'hail_2', 'bgrun', 'cfrzr', 'cape', 'pwat', 'sh2']\n",
            "Correlations: ['nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', 'nan', '0.1192', '0.0897', '0.0836']\n"
          ]
        }
      ],
      "source": [
        "# Identify top-20 weather features by correlation with outages (from EDA)\n",
        "out_flat = outage.reshape(-1)\n",
        "w_flat = weather.reshape(-1, F)\n",
        "correlations = np.array([np.corrcoef(w_flat[:, i], out_flat)[0, 1] for i in range(F)])\n",
        "corr_rank = np.argsort(np.abs(correlations))[::-1]\n",
        "\n",
        "TOP_K = 20\n",
        "top_feat_idx = corr_rank[:TOP_K]\n",
        "top_feat_names = [features[i] for i in top_feat_idx]\n",
        "print(f\"Top {TOP_K} features: {top_feat_names}\")\n",
        "print(f\"Correlations: {[f'{correlations[i]:.4f}' for i in top_feat_idx]}\")\n",
        "\n",
        "# Subset for rolling stats (top 5 only to keep feature count manageable)\n",
        "TOP_ROLL = 5\n",
        "roll_feat_idx = corr_rank[:TOP_ROLL]\n",
        "roll_feat_names = [features[i] for i in roll_feat_idx]"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "metadata": {
        "colab": {
