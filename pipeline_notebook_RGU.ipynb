        "# =====================================================\n",
        "# LSTM: Prediction function\n",
        "# =====================================================\n",
        "\n",
        "@torch.no_grad()\n",
        "def predict_lstm(model, outage_z, weather_pca, lookback, horizon,\n",
        "                 pred_timestamps, locations, out_mu, out_sd):\n",
        "    \"\"\"\n",
        "    Generate LSTM predictions using last lookback window from available data.\n",
        "    \"\"\"\n",
        "    model.eval()\n",
        "    T_w, L_w = outage_z.shape\n",
        "    N_pca = weather_pca.shape[2]\n",
        "\n",
        "    rows = []\n",
        "    for li in range(L_w):\n",
        "        # Build input: last lookback window\n",
        "        out_loc = outage_z[-lookback:, li].reshape(-1, 1)   # (lookback, 1)\n",
        "        w_loc = weather_pca[-lookback:, li, :]               # (lookback, N_pca)\n",
        "        x = np.column_stack([out_loc, w_loc])                # (lookback, 1+N_pca)\n",
        "        x_t = torch.tensor(x, dtype=torch.float32).unsqueeze(0).to(DEVICE)  # (1, lookback, D)\n",
        "\n",
        "        pred_z = model(x_t).cpu().numpy().flatten()  # (horizon,)\n",
        "        pred_raw = z_denorm(pred_z, out_mu, out_sd)\n",
        "        pred_raw = np.clip(pred_raw, 0, None)  # non-negative\n",
        "\n",
        "        for h in range(horizon):\n",
        "            rows.append({\n",
        "                'timestamp': pred_timestamps[h],\n",
        "                'location': str(locations[li]),\n",
        "                'pred': pred_raw[h]\n",
        "            })\n",
        "\n",
        "    df = pd.DataFrame(rows)\n",
        "    df = df.sort_values(['timestamp', 'location']).reset_index(drop=True)\n",
        "    return df\n",
        "\n",
        "print(\"LSTM prediction function ready.\")"
      ]
    },
