        "\n",
        "print(f\"LSTM Config: PCA={N_PCA}, lookback={LOOKBACK}, hidden={HIDDEN_DIM}, \"\n",
        "      f\"layers={NUM_LAYERS}, dropout={DROPOUT}, epochs={EPOCHS}\")\n",
        "\n",
        "# Fit PCA on training weather data\n",
        "w_train_flat = weather_train.reshape(-1, F)  # (T_train * L, F)\n",
        "w_scaler = StandardScaler()\n",
        "w_train_scaled = w_scaler.fit_transform(w_train_flat)\n",
        "\n",
        "pca = PCA(n_components=N_PCA, random_state=RANDOM_SEED)\n",
        "pca.fit(w_train_scaled)\n",
        "print(f\"PCA explained variance: {pca.explained_variance_ratio_.sum():.4f}\")\n",
        "\n",
        "# Transform all weather data\n",
        "def apply_pca_weather(weather_arr, scaler, pca_model):\n",
        "    \"\"\"Apply StandardScaler + PCA to weather array (T, L, F) -> (T, L, N_PCA)\"\"\"\n",
        "    T_w, L_w, F_w = weather_arr.shape\n",
        "    flat = weather_arr.reshape(-1, F_w)\n",
        "    scaled = scaler.transform(flat)\n",
        "    transformed = pca_model.transform(scaled)\n",
        "    return transformed.reshape(T_w, L_w, -1)\n",
        "\n",
        "weather_train_pca = apply_pca_weather(weather_train, w_scaler, pca)\n",
        "weather_full_pca = apply_pca_weather(weather, w_scaler, pca)\n",
        "\n",
        "print(f\"PCA weather shape (train): {weather_train_pca.shape}\")"
      ]
